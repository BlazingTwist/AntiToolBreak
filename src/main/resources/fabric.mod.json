{
  "schemaVersion": 1,
  "id": "antitoolbreak",
  "version": "${version}",

  "name": "Anti Tool Break",
  "description": "Stops you from using your precious tools before they break.",
  "authors": [
    "BlazingTwist"
  ],
  "contact": {
    "homepage": "https://github.com/BlazingTwist",
    "sources": "https://github.com/BlazingTwist/AntiToolBreak"
  },

  "license": "Apache-2.0",
  "icon": "assets/antitoolbreak/icon128.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "blazingtwist.antitoolbreak.AntiToolBreak"
    ],
    "modmenu": [
      "blazingtwist.antitoolbreak.AntiToolBreakModMenuImpl"
    ]
  },
  "mixins": [
    {
      "config": "antitoolbreak.mixins.json",
      "environment": "client"
    }
  ],

  "depends": {
    "fabricloader": ">=0.16.14",
    "fabric-api": "*",
    "minecraft": ">=26",
    "java": ">=25"
  },
  "custom": {
    "modmenu:clientsideOnly": true
  }
}
